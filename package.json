{
  "name": "app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run i18n:merge && set -a && source .env && set +a && bun run vite dev",
    "build": "bun run i18n:merge && if [ -f .env ]; then set -a && source .env && set +a; fi && bun run vite build",
    "preview": "vite preview",
    "start": "if [ -f .env ]; then set -a && source .env && set +a; fi && echo \"\" && echo \"🚀 Server is ready at: http://localhost:${PUBLIC_APP_BASE_PORT:-3001}${PUBLIC_APP_BASE_PATH:-/}\" && echo \"\" && PORT=${PUBLIC_APP_BASE_PORT:-3001} node build/index.js",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "i18n:merge": "bun scripts/mergeI18n.js",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@inlang/cli": "^3.0.0",
    "@inlang/paraglide-js": "^2.10.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.2",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.1.0",
    "serve": "^14.2.5",
    "svelte": "^5.48.2",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@iconify/svelte": "^5.2.1",
    "apexcharts": "^5.3.6",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "jsvectormap": "^1.7.0",
    "leaflet": "^1.9.4",
    "lity": "^2.4.1",
    "perfect-scrollbar": "^1.5.6",
    "sass": "1.71.1",
    "svelte-apexcharts": "^1.0.2",
    "svelte-highlight": "^7.9.0"
  }
}
