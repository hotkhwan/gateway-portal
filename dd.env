PUBLIC_APP_BASE_PATH=/aisom
PUBLIC_APP_BASE_PORT=3001

# API version — change here to affect all api calls
# apiFetch will use: /aisom/api/${PUBLIC_API_VERSION}/...
PUBLIC_API_VERSION=v1

API_BASE=https://gateway.aisom.cloud/api/v1
PUBLIC_KC_ISSUER_URI=https://gateway.aisom.cloud/sso
PUBLIC_KC_REALM=aisom
PUBLIC_KC_CLIENT_FE_ID=fe

AUTH_REFRESH_PATH=/auth/refreshToken
AUTH_REFRESH_SKEW_SEC=45
COOKIE_SECURE=false

PUBLIC_GOOGLE_MAP_TOKEN=AIzaSy...
